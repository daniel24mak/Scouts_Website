# General text handling
* text=auto

# Force code/config files to LF line endings
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.mjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf

# Shell/scripts
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Images should be treated as binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.avif binary

# SVG is text but should use LF
*.svg text eol=lf

# Fonts should be binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Documents and archives should be binary
*.pdf binary
*.docx binary
*.xlsx binary
*.xls binary
*.pptx binary
*.zip binary
*.rar binary
*.7z binary

# Media files should be binary
*.mp4 binary
*.mov binary
*.mp3 binary
*.wav binary
